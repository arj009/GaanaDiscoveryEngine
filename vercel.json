{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd gaana-discovery-engine/dashboard && npm install",
  "buildCommand": "cd gaana-discovery-engine/dashboard && npm run build",
  "devCommand": "cd gaana-discovery-engine/dashboard && npm run dev",
  "outputDirectory": "gaana-discovery-engine/dashboard/dist",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/enriched_reviews.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.svg|icons\\.svg|enriched_reviews\\.json).*)",
      "destination": "/index.html"
    }
  ]
}
